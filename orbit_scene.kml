<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Orbit Scene</name>

    <LookAt>
      <longitude>-100.0</longitude>
      <latitude>40.0</latitude>
      <range>5000000</range>
      <tilt>45</tilt>
      <heading>0</heading>
    </LookAt>

    <Placemark>
      <name>Orbiting Dinosaur Area</name>
      <description>Camera view for Liquid Galaxy orbit visualization</description>
      <Point>
        <coordinates>-100.0,40.0,0</coordinates>
      </Point>
    </Placemark>

  </Document>
</kml>
